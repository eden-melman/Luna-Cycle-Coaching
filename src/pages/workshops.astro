---
import Layout from "../layouts/Layout.astro";

const description =
  "Corporate workshops on cycle-aware training and recovery for women's teams. London-based, sports-science-led. Spring is heavily booked — enquire early.";

const formats = [
  {
    n: "60",
    unit: "minutes",
    name: "Keynote primer",
    blurb: "A single, evidence-led talk for an internal lunch-and-learn or women's-network event. Covers the four phases, what changes in the body, and three things to do on Monday.",
  },
  {
    n: "180",
    unit: "minutes",
    name: "Half-day workshop",
    blurb: "Talk plus a working session — your team leaves with a personal cycle-tracking starting point and a phase-aware training framework for their existing routine.",
  },
  {
    n: "8",
    unit: "weeks",
    name: "Embedded programme",
    blurb: "Six sessions across eight weeks. The team is coached through a full cycle, with written check-ins and a wrap-up debrief for HR or the wellbeing lead.",
  },
];

const audiences = [
  "Women's networks and ERGs running a flagship event",
  "Tech and finance teams adding a credible wellness pillar",
  "Sports clubs and fitness studios adding a women-specific track",
  "Performance and athletics departments rebuilding programming on female physiology",
];

const enquiryJsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Corporate wellness workshop",
  name: "Cycle-aware training workshops",
  description,
  areaServed: "London, UK",
  provider: { "@type": "HealthAndBeautyBusiness", name: "Luna Cycle Coaching" },
};
---

<Layout title="Corporate workshops" description={description} pathname="/workshops" jsonLd={enquiryJsonLd}>
  <section class="max-w-[var(--container-max)] mx-auto px-5 md:px-16 pt-16 md:pt-24 pb-12 grid grid-cols-1 md:grid-cols-12 gap-12 items-end">
    <div class="md:col-span-8">
      <div class="text-eyebrow text-[var(--color-accent)] mb-4">Corporate workshops</div>
      <h1 class="text-display max-w-[20ch]">Train your team to train with their cycles.</h1>
      <p class="mt-8 text-body-lg max-w-2xl text-[var(--color-text-muted)]">
        Cycle-aware training and recovery workshops for women's networks, performance teams, and studios in London. Evidence-led, never pink, never patronising. Spring is heavily booked — enquire by mid-February for a March–May slot.
      </p>
    </div>
    <div class="md:col-span-4">
      <div class="border-t-2 border-[var(--color-primary)] pt-6">
        <div class="text-eyebrow text-[var(--color-text-muted)] mb-3">Booking status</div>
        <ul class="space-y-2 text-sm text-[var(--color-text)]">
          <li>· March 2026 — fully booked</li>
          <li>· April 2026 — 1 slot remaining</li>
          <li>· May 2026 — taking enquiries</li>
          <li>· June onward — open</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="max-w-[var(--container-max)] mx-auto px-5 md:px-16 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-[var(--color-border)] border border-[var(--color-border)]">
      {formats.map((f) => (
        <article class="bg-[var(--color-surface)] p-8 md:p-10" data-reveal>
          <div class="flex items-baseline gap-3">
            <span class="text-stats text-[var(--color-primary)]">{f.n}</span>
            <span class="text-eyebrow text-[var(--color-text-muted)]">{f.unit}</span>
          </div>
          <h2 class="mt-4 text-2xl font-[family-name:var(--font-display)] font-semibold text-[var(--color-primary)]">
            {f.name}
          </h2>
          <p class="mt-6 text-[var(--color-text-muted)] leading-relaxed">{f.blurb}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-[var(--color-surface-2)]/50 border-y border-[var(--color-border)]">
    <div class="max-w-[var(--container-max)] mx-auto px-5 md:px-16 py-24 grid grid-cols-1 md:grid-cols-12 gap-12" data-reveal>
      <div class="md:col-span-5">
        <div class="text-eyebrow text-[var(--color-accent)] mb-4">Who books these</div>
        <h2 class="text-display-sm">Teams who want substance, not a step-counter.</h2>
      </div>
      <ul class="md:col-span-7 md:col-start-6 divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
        {audiences.map((a, i) => (
          <li class="py-6 flex gap-6 items-start">
            <span class="text-eyebrow text-[var(--color-text-muted)] w-10">{String(i + 1).padStart(2, "0")}</span>
            <span class="text-[var(--color-text)]">{a}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section>
    <div class="max-w-[var(--container-max)] mx-auto px-5 md:px-16 py-24 grid grid-cols-1 md:grid-cols-12 gap-12 items-start" data-reveal>
      <div class="md:col-span-5">
        <div class="text-eyebrow text-[var(--color-accent)] mb-4">Enquire about a workshop</div>
        <h2 class="text-display-sm">Tell me about your team.</h2>
        <p class="mt-6 text-[var(--color-text-muted)]">
          A short email with team size, your preferred format and rough timing is all I need to come back with a proposal and a fixed price.
        </p>
        <ul class="mt-8 space-y-3 text-[var(--color-text)] text-sm">
          <li>· Group size — 8 to 80 works best in person</li>
          <li>· Format — see the three on this page</li>
          <li>· Timing — earliest workable date</li>
          <li>· Why now — the problem you're trying to solve</li>
        </ul>
      </div>
      <form id="workshop-form" class="md:col-span-6 md:col-start-7 bg-[var(--color-surface)] border border-[var(--color-border)] p-8 md:p-10 flex flex-col gap-6" novalidate>
        <div>
          <label class="text-eyebrow text-[var(--color-text-muted)] block mb-2" for="workshop-name">Your name</label>
          <input class="field-input" type="text" id="workshop-name" name="name" required />
        </div>
        <div>
          <label class="text-eyebrow text-[var(--color-text-muted)] block mb-2" for="workshop-email">Work email</label>
          <input class="field-input" type="email" id="workshop-email" name="email" required />
        </div>
        <div>
          <label class="text-eyebrow text-[var(--color-text-muted)] block mb-2" for="workshop-company">Company / team</label>
          <input class="field-input" type="text" id="workshop-company" name="company" required />
        </div>
        <div>
          <label class="text-eyebrow text-[var(--color-text-muted)] block mb-2" for="workshop-format">Format</label>
          <select class="field-input" id="workshop-format" name="format">
            <option value="">Choose…</option>
            <option>Keynote primer — 60 min</option>
            <option>Half-day workshop — 180 min</option>
            <option>Embedded programme — 8 weeks</option>
            <option>I'm not sure yet</option>
          </select>
        </div>
        <div>
          <label class="text-eyebrow text-[var(--color-text-muted)] block mb-2" for="workshop-notes">What are you trying to solve?</label>
          <textarea class="field-input" id="workshop-notes" name="notes" rows="5"></textarea>
        </div>
        <div id="workshop-error" class="hidden text-sm text-[var(--color-accent)] border-l-2 border-[var(--color-accent)] pl-3"></div>
        <div id="workshop-success" class="hidden text-sm text-[var(--color-primary)] border-l-2 border-[var(--color-primary)] pl-3">
          Got it. I'll reply within two working days with availability and a fixed price.
        </div>
        <button id="workshop-submit" type="submit" class="btn-primary self-start">Enquire about a workshop</button>
        <p class="text-xs text-[var(--color-text-muted)]">I'll reply within two working days with availability and a fixed price.</p>
      </form>

      <script is:inline>
        (function () {
          const form = document.getElementById("workshop-form");
          const errBox = document.getElementById("workshop-error");
          const okBox = document.getElementById("workshop-success");
          const btn = document.getElementById("workshop-submit");
          if (!form) return;

          function show(el, msg) {
            el.textContent = msg || el.textContent;
            el.classList.remove("hidden");
          }
          function hide(el) { el.classList.add("hidden"); }

          form.addEventListener("submit", async function (e) {
            e.preventDefault();
            hide(errBox); hide(okBox);

            const data = Object.fromEntries(new FormData(form).entries());
            if (!data.name || !data.email || !data.company) {
              show(errBox, "Add your name, work email and company to enquire.");
              return;
            }

            btn.disabled = true;
            btn.textContent = "Sending…";
            try {
              const res = await fetch("/api/workshops", {
                method: "POST",
                headers: { "content-type": "application/json" },
                body: JSON.stringify(data),
              });
              const payload = await res.json().catch(function () { return {}; });
              if (!res.ok || payload.ok === false) {
                show(errBox, payload.error || "Something went wrong. Please try again.");
              } else {
                form.reset();
                show(okBox);
              }
            } catch (err) {
              show(errBox, "Network problem. Please try again.");
            } finally {
              btn.disabled = false;
              btn.textContent = "Enquire about a workshop";
            }
          });
        })();
      </script>
    </div>
  </section>
</Layout>
