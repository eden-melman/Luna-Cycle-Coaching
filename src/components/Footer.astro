---
const year = new Date().getFullYear();
---

<footer class="bg-[var(--color-dark)] text-[var(--color-on-dark)] mt-24">
  <div class="max-w-[var(--container-max)] mx-auto px-5 md:px-16 py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-16">
      <div class="md:col-span-5">
        <div class="font-[family-name:var(--font-display)] text-2xl md:text-3xl font-semibold mb-4">
          Luna Cycle Coaching
        </div>
        <p class="text-body-lg max-w-md opacity-80">
          Strength and conditioning for women, mapped to the four-phase menstrual cycle. London-based, evidence-led, never pink.
        </p>
        <div class="mt-8">
          <a href="/intake" class="inline-flex items-center gap-2 text-caps text-[var(--color-accent-bright)] border-b border-[var(--color-accent-bright)] pb-1">
            Book a free consult
            <span aria-hidden>→</span>
          </a>
        </div>
      </div>

      <div class="md:col-span-2">
        <div class="text-eyebrow text-[var(--color-accent-bright)] mb-4">Site</div>
        <ul class="flex flex-col gap-3 text-sm">
          <li><a href="/programs" class="hover:text-[var(--color-accent-bright)]">Programs</a></li>
          <li><a href="/science" class="hover:text-[var(--color-accent-bright)]">The Science</a></li>
          <li><a href="/coach" class="hover:text-[var(--color-accent-bright)]">Your Coach</a></li>
          <li><a href="/workshops" class="hover:text-[var(--color-accent-bright)]">Workshops</a></li>
          <li><a href="/faq" class="hover:text-[var(--color-accent-bright)]">FAQ</a></li>
          <li><a href="/intake" class="hover:text-[var(--color-accent-bright)]">Intake</a></li>
        </ul>
      </div>

      <div class="md:col-span-2">
        <div class="text-eyebrow text-[var(--color-accent-bright)] mb-4">Connect</div>
        <ul class="flex flex-col gap-3 text-sm">
          <li><a href="https://instagram.com/lunacyclecoaching" rel="me" class="hover:text-[var(--color-accent-bright)]">@lunacyclecoaching</a></li>
          <li><a href="https://instagram.com/trainwithyourcycle" rel="me" class="hover:text-[var(--color-accent-bright)]">@trainwithyourcycle</a></li>
        </ul>
      </div>

      <div class="md:col-span-3">
        <div class="text-eyebrow text-[var(--color-accent-bright)] mb-4">Practice</div>
        <ul class="flex flex-col gap-2 text-sm opacity-80">
          <li>London, UK</li>
          <li>Mon–Fri · 07:00–19:00</li>
          <li>Saturday · 09:00–13:00</li>
          <li>Established 2020</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--color-on-dark)]/15 pt-8 flex flex-col md:flex-row md:justify-between gap-4 text-xs opacity-70">
      <span>© {year} Luna Cycle Coaching. All rights reserved.</span>
      <span class="text-eyebrow opacity-80">Editorial Sports-Science · Evidence-led training</span>
    </div>
  </div>
</footer>
